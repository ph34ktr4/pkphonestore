{
  "name": "phoneshop",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev:all": "concurrently -k -n backend,frontend -c green,cyan \"npm --prefix phoneshop-backend run dev\" \"npm run start\"",
    "seed": "npm --prefix phoneshop-backend run seed",
    "start": "ng serve --host 0.0.0.0 --port 4201 --project phoneshop --proxy-config proxy.conf.json",
    "start:4200": "ng serve --host 0.0.0.0 --port 4200 --project phoneshop --proxy-config proxy.conf.json",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "start:prod": "npm run build:prod; npm --prefix phoneshop-backend run start",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "concurrently": "^9.1.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}